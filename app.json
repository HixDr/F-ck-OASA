{
  "expo": {
    "name": "F*ck OASA",
    "slug": "fck-oasa",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "scheme": "fck-oasa",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.itshix.fckoasa"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#000000"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "package": "com.itshix.fckoasa",
      "config": {
        "googleMaps": {
          "apiKey": "REDACTED_API_KEY"
        }
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Used to find nearby bus stops."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notif-icon.png",
          "sounds": ["./assets/arrival.mp3"]
        }
      ],
      "expo-font",
      "./plugins/withAndroidOptimizations"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "4fab4ff0-2a2e-4acb-ba11-d827c6c0ad26"
      }
    }
  }
}
